# Supply Chain AI Operating System - Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_USER=supplychain
# Change this in production — use a strong, randomly generated password
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=supply_chain_db
POSTGRES_PORT=5433

# Full connection URL (used by FastAPI, pg-writer, alembic)
# Inside Docker the host is "postgres" (service name), outside use "localhost"
DATABASE_URL=postgresql://supplychain:change_me_in_production@localhost:5433/supply_chain_db

# Connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# =============================================================================
# SECURITY
# =============================================================================
# Minimum 32 characters — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_32_chars_minimum_replace_this_value

# Salt used for API key hashing
API_KEY_SALT=change_me

# ── API Key Authentication ────────────────────────────────────────────────────
# Comma-separated list of valid API keys for all protected endpoints.
# Generate with: python -c "import secrets; print('sc-' + secrets.token_hex(24))"
# Leave empty to DISABLE authentication (local dev only — never empty in production).
# Usage: Authorization: Bearer <key>  OR  X-API-Key: <key>
API_KEYS= 

# Comma-separated list of trusted hosts (no wildcards in production)
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated CORS origins (no wildcards in production)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# AI endpoint rate limit (requests per minute per IP, default 30)
AI_RATE_LIMIT_PER_MIN=30

# =============================================================================
# KAFKA
# =============================================================================
# Use port 9093 when connecting from the host; 9092 inside Docker network
KAFKA_BOOTSTRAP_SERVERS=localhost:9093
KAFKA_TOPIC=supply-chain-events

# =============================================================================
# OBJECT STORAGE (MinIO / S3-compatible)
# =============================================================================
MINIO_ROOT_USER=minioadmin
# Change this in production
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=supply-chain-lakehouse
S3_STORAGE_BUCKET=supply-chain-lakehouse

# AWS-compatible credentials for Delta Lake / PySpark
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=change_me_in_production
AWS_ENDPOINT_URL=http://localhost:9000

# =============================================================================
# REDIS (WebSocket pub/sub)
# =============================================================================
REDIS_URL=redis://localhost:6379/0
# Redis AUTH password — required in production (docker-compose.prod.yml enforces this)
# Generate with: python -c "import secrets; print(secrets.token_hex(24))"
REDIS_PASSWORD=change_me_redis

# =============================================================================
# AI REASONING
# =============================================================================
# Required — get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Claude model to use for analysis
CLAUDE_MODEL=claude-sonnet-4-6

# Confidence threshold for autonomous action execution (0.0–1.0)
AUTONOMY_CONFIDENCE_THRESHOLD=0.70

# =============================================================================
# DAGSTER (Pipeline Orchestration)
# =============================================================================
DAGSTER_POSTGRES_HOST=localhost
DAGSTER_POSTGRES_PORT=5432
DAGSTER_POSTGRES_USER=supplychain
DAGSTER_POSTGRES_PASSWORD=change_me_in_production
DAGSTER_POSTGRES_DB=dagster

# =============================================================================
# FRONTEND (Next.js)
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# =============================================================================
# OBSERVABILITY (Grafana + Loki + Prometheus + Alloy)
# =============================================================================
GRAFANA_USER=admin
# Change this in production
GRAFANA_PASSWORD=change_me_in_production
# Production domain (used by docker-compose.prod.yml Grafana config)
GRAFANA_DOMAIN=localhost

# ── Loki (log aggregation) ────────────────────────────────────────────────────
# LOCAL: default, no config needed — Loki runs in docker-compose on port 3100
# CLOUD: set to your Grafana Cloud Loki push URL (free tier: 50GB/month)
#   Format: https://<user>@logs-prod-<region>.grafana.net/loki/api/v1/push
LOKI_URL=http://loki:3100/loki/api/v1/push

# ── Prometheus (metrics) ──────────────────────────────────────────────────────
# LOCAL: default — Prometheus runs in docker-compose on port 9090
# CLOUD: set to your Grafana Cloud Mimir remote write URL
PROMETHEUS_REMOTE_WRITE_URL=http://prometheus:9090/api/v1/write

# ── Grafana Cloud (optional, free tier) ──────────────────────────────────────
# Uncomment and populate ONLY if shipping to Grafana Cloud instead of local Loki/Prometheus
# GRAFANA_CLOUD_LOKI_URL=https://logs-prod-<region>.grafana.net/loki/api/v1/push
# GRAFANA_CLOUD_LOKI_USER=<your-loki-user-id>
# GRAFANA_CLOUD_LOKI_API_KEY=<your-grafana-cloud-api-key>
# GRAFANA_CLOUD_METRICS_USER=<your-metrics-user-id>
# GRAFANA_CLOUD_METRICS_API_KEY=<your-grafana-cloud-api-key>

# Application environment tag (added to all logs/metrics as label)
APP_ENV=local

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
# Set to "true" to log all SQL statements (development only)
SQL_ECHO=false

# =============================================================================
# OPTIONAL: Slack Alerting
# =============================================================================
# Set to receive Slack notifications for CRITICAL deviations
SLACK_WEBHOOK_URL=

# =============================================================================
# OPTIONAL: dbt
# =============================================================================
DBT_PROFILES_DIR=./transforms
DBT_TARGET=dev

# =============================================================================
# OPTIONAL: Kafka Dead Letter Queue
# =============================================================================
KAFKA_DLQ_TOPIC=supply-chain-dlq

# =============================================================================
# OPTIONAL: OpenBoxes Connector (free, open-source WMS/SCM)
# =============================================================================
# OPENBOXES_MOCK=true  → generates realistic OpenBoxes-style mock payloads (default, no server needed)
# OPENBOXES_MOCK=false → connects to live OpenBoxes REST API
#
# Free public demo (no signup, no API key): https://demo.openboxes.com/openboxes
#   Username: admin  |  Password: password
#
# Self-hosted: docker run -p 8080:8080 openboxes/openboxes:latest
OPENBOXES_MOCK=true
OPENBOXES_URL=https://demo.openboxes.com/openboxes
OPENBOXES_USERNAME=admin
OPENBOXES_PASSWORD=password
OPENBOXES_POLL_INTERVAL=30
OPENBOXES_BATCH_SIZE=10

# =============================================================================
# OPTIONAL: OpenLineage / Marquez
# =============================================================================
# Leave empty to disable Marquez integration (lineage still written to Postgres)
MARQUEZ_URL=
LINEAGE_NAMESPACE=supply-chain-os

# =============================================================================
# OPTIONAL: MLflow Experiment Tracking
# =============================================================================
# Inside Docker: http://mlflow:5000  |  From host: http://localhost:5001
MLFLOW_TRACKING_URI=http://localhost:5001

# =============================================================================
# OPTIONAL: OpenTelemetry / Jaeger Tracing
# =============================================================================
# Set OTEL_ENABLED=false to disable tracing
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=supply-chain-api
# Jaeger UI available at: http://localhost:16686

# =============================================================================
# OPTIONAL: ksqlDB Streaming Aggregations
# =============================================================================
KSQLDB_URL=http://localhost:8088

# =============================================================================
# OPTIONAL: Multi-model AI (GPT-4o fallback)
# =============================================================================
# Leave empty to use Claude only (no fallback)
OPENAI_API_KEY=

# ============================================================
# AUTONOMOUS AGENT SYSTEM
# ============================================================

# Claude models for agents
AGENT_MODEL_HAIKU=claude-haiku-4-5-20251001
AGENT_MODEL_SONNET=claude-sonnet-4-6

# Agent thresholds
KAFKA_LAG_WARN=500
KAFKA_LAG_CRITICAL=2000
DLQ_SPIKE_THRESHOLD=10
PRODUCER_SILENCE_SECONDS=120
AI_MIN_CONFIDENCE=0.4
AI_STUCK_THRESHOLD_MIN=10
BRONZE_STALE_THRESHOLD_MIN=30
GOLD_FRESHNESS_THRESHOLD_MIN=360
ASSET_FRESHNESS_THRESHOLD_MIN=420
DB_MAX_CONNECTIONS_WARN=80
DB_LONG_QUERY_SEC=30
MAX_PENDING_ACTIONS_WARN=50

# Internal API key for agent-to-API calls
API_KEY_INTERNAL=internal-monitor-key-change-in-prod

# Agent startup delay (seconds, wait for infra)
AGENT_STARTUP_DELAY=45
